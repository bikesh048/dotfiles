{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAM": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm run *)",
      "Bash(pnpm exec prisma *)",
      "Bash(npx prisma *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git worktree*)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook user-prompt-submit"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook pre-compact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook post-compact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook stop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @iyadhk/clauditor hook post-tool-use"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{hookSpecificOutput: {hookEventName: \"PostToolUseFailure\", additionalContext: (\"⚠️ Terminal error detected!\\n\\nFailed command:\\n\" + (.tool_input.command // \"unknown\") + \"\\n\\nError output:\\n\" + (.tool_response.output // (.tool_response | tostring)) + \"\\n\\nDiagnose this error, identify the root cause, and suggest a specific fix. Do NOT auto-apply changes — present your diagnosis and recommendation clearly so the user can decide.\")}}' 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Diagnosing terminal error..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "oh-my-claudecode@oh-my-claudecode": true,
    "obsidian@obsidian-skills": true,
    "oh-my-claudecode@omc": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "oh-my-claudecode": {
      "source": {
        "source": "github",
        "repo": "Yeachan-Heo/oh-my-claudecode"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "mcpServers": {
    "token-savior-recall": {
      "command": "uvx",
      "args": [
        "token-savior-recall"
      ],
      "env": {
        "WORKSPACE_ROOTS": "/Users/bikeshrestha/codewing-projects/tripcart",
        "TOKEN_SAVIOR_CLIENT": "claude-code"
      }
    }
  }
}
